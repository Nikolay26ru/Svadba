# Example environment file. Copy to /opt/svadba/svadba.env on the server and
# fill in real values. NEVER commit the real file — it holds secrets.
# The deploy script (deploy/deploy.sh) generates this file for you.

# Flask session signing key (random 64 hex chars)
SECRET_KEY=change-me-to-a-long-random-value

# Admin password stored as a werkzeug hash (NOT the plain password)
# Generate: python3 -c "from werkzeug.security import generate_password_hash as g; print(g('YOURPASS'))"
ADMIN_PASSWORD_HASH=pbkdf2:sha256:...

# Secret URL segment for the admin panel, e.g. admin-7f3a9c2b
ADMIN_PATH=admin

# Send session cookies only over HTTPS (set true once TLS is active)
COOKIE_SECURE=false

# Public base URL used to build invite links shown in the admin panel
BASE_URL=https://kostya-i-gera.ru

# Database location (persistent, outside the code dir)
DB_PATH=/opt/svadba/data/svadba.db

# Brute-force protection
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900

# Event
WEDDING_DATE=26.06.2026
DISPLAY_TZ=Europe/Moscow

# E-mail notifications (BeGet)
MAIL_ENABLED=false
MAIL_USER=info@kostya-i-gera.ru
MAIL_PASS=
MAIL_TO=info@kostya-i-gera.ru
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_MODE=ssl
